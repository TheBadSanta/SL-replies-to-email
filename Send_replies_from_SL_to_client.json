    {
      "parameters": {
        "jsCode": "  const history = $input.first().json.history;                                                                                                   \n  const sent = history.filter(m => m.type === 'SENT');                                                                                           \n  const lastSent = sent[sent.length - 1];                                                                                                        \n  const reply = history.find(m => m.type === 'REPLY');                                                                                           \n                                                                  \n    function stripHtml(html) {                                                                                                                                      \n    html = html.replace(/<blockquote[\\s\\S]*?<\\/blockquote>/gi, '');\n    // Convert block elements to newlines                                                                                                                         \n    html = html.replace(/<br\\s*\\/?>/gi, '\\n');                                                                                                                    \n    html = html.replace(/<\\/p>/gi, '\\n\\n');                                                                                                                       \n    html = html.replace(/<\\/div>/gi, '\\n');                                                                                                                       \n    // Remove remaining tags                                                                                                                                      \n    html = html.replace(/<[^>]+>/g, '');\n    // Decode entities                                                                                                                                            \n    html = html.replace(/&quot;/g, '\"').replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&nbsp;/g, ' ');                               \n    // Clean up excessive newlines                                                                                                                                \n    html = html.replace(/\\n{3,}/g, '\\n\\n').trim();                                                                                                                \n    return html;                                                                                                                                                  \n  }\n function stripHtml(html) {                                                                                                                                      \n    html = html.replace(/<blockquote[\\s\\S]*?<\\/blockquote>/gi, '');\n    html = html.replace(/<br\\s*\\/?>/gi, '\\n');\n    html = html.replace(/<\\/p>/gi, '\\n\\n');                                                                                                                       \n    html = html.replace(/<\\/div>/gi, '\\n');\n    html = html.replace(/<[^>]+>/g, '');                                                                                                                          \n    html = html.replace(/&quot;/g, '\"').replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&nbsp;/g, ' ');\n    html = html.replace(/\\n{3,}/g, '\\n\\n').trim();                                                                                                                \n    // Convert back to <br> for HTML email rendering              \n    html = html.replace(/\\n/g, '<br>');                                                                                                                           \n    return html;                                                  \n  } \n                                                                                                                                                 \n  return [{                                                       \n    json: {\n      last_sent: stripHtml(lastSent.email_body),\n      reply: stripHtml(reply.email_body),                                                                                                        \n      subject: lastSent.subject,\n      seq_number: reply.email_seq_number, \n    }                                                                                                                                            \n  }]; "
      },
